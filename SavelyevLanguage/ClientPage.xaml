<Page x:Class="SavelyevLanguage.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SavelyevLanguage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientPage" FontFamily="Comic Sans MS"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="10,0,0,0">
                <TextBlock Text="Поиск:  " FontSize="15" HorizontalAlignment="Left" VerticalAlignment="Center"></TextBlock>
                <TextBox Name="SearchTB" Height="20" Width="230" HorizontalAlignment="Left" VerticalAlignment="Center" TextChanged="SearchTB_TextChanged"></TextBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Пол:  " FontSize="15" HorizontalAlignment="Left" VerticalAlignment="Center"></TextBlock>
                <ComboBox Name="GenderCB" Height="20" Width="80" FontSize="12" SelectionChanged="GenderCB_SelectionChanged">
                    <TextBlock>Все</TextBlock>
                    <TextBlock>Мужской</TextBlock>
                    <TextBlock>Женский</TextBlock>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Column="2" Margin="10,0,0,0">
                <TextBlock Text="Сортировка:  " FontSize="15" HorizontalAlignment="Left" VerticalAlignment="Center"></TextBlock>
                <ComboBox Name="SortCB" Height="20" Width="220" FontSize="12" SelectionChanged="SortCB_SelectionChanged">
                    <TextBlock>Нет</TextBlock>
                    <TextBlock>По фамилии от А до Я</TextBlock>
                    <TextBlock>По дате последнего посещения</TextBlock>
                    <TextBlock>По количеству посещений</TextBlock>
                </ComboBox>
            </StackPanel>

            <Button Name="AddBtn" Content="Добавить" Grid.Column="3" Click="AddBtn_Click" Margin="15,0,0,0"></Button>
        </Grid>

        <ListView Name="ClientListView" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="520"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>

                            <Image Width="130" Stretch="Uniform" Grid.Column="0" Grid.RowSpan="5">
                                <Image.Source>
                                    <Binding Path="ClientPhotoPath">
                                        <Binding.TargetNullValue>
                                            <ImageSource>
                                                res/picture.png
                                            </ImageSource>
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Image.Source>
                            </Image>
                            
                            <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="0" Margin="10,0,0,0">
                                <TextBlock Text="{Binding ID, StringFormat=ID: {0}}" FontSize="17" HorizontalAlignment="Left" FontWeight="Bold"></TextBlock>
                                <TextBlock Text="   "></TextBlock>
                                <TextBlock Text="{Binding FullName}" FontSize="17" HorizontalAlignment="Left" FontWeight="Bold"></TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="1" Margin="10,0,0,0">
                                <TextBlock Text="{Binding GenderName,StringFormat=Пол: {0}}" FontSize="15" HorizontalAlignment="Left"></TextBlock>
                                <TextBlock Text="   "></TextBlock>
                                <TextBlock Text="{Binding Birthday, StringFormat=Дата рождения: {0:dd.MM.yyyy}}" FontSize="15" HorizontalAlignment="Left"></TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="2" Margin="10,0,0,0">
                                <TextBlock Text="{Binding Phone, StringFormat=Телефон: {0}}" FontSize="15" HorizontalAlignment="Left"></TextBlock>
                                <TextBlock Text="   "></TextBlock>
                                <TextBlock Text="{Binding Email, StringFormat=Email: {0}}" FontSize="15" HorizontalAlignment="Left"></TextBlock>
                            </StackPanel>

                            <TextBlock Text="{Binding RegistrationDate, StringFormat=Дата регистрации: {0:dd.MM.yyyy}}" Grid.Column="1" Grid.Row="3" 
                                       FontSize="15" HorizontalAlignment="Left" Margin="10,0,0,0"></TextBlock>
                            
                            <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="4" Margin="10,0,0,0">
                                <TextBlock Text="{Binding LastVisitDate, StringFormat=Дата последнего посещения: {0:dd.MM.yyyy},
                                    TargetNullValue='Дата последнего посещения: нет'}" FontSize="15" HorizontalAlignment="Left"></TextBlock>
                                <TextBlock Text="   "></TextBlock>
                                <TextBlock Text="{Binding VisitsCount, StringFormat=Кол-во посещений: {0}}" FontSize="15" HorizontalAlignment="Left"></TextBlock>
                            </StackPanel>

                            <Button Content="Удалить" Name="DeleteBtn" Grid.Column="2" Grid.Row="1" HorizontalAlignment="Center" Click="DeleteBtn_Click"></Button>
                            <Button Content="Редактировать" Name="EditBtn" Grid.Column="2" Grid.Row="3" HorizontalAlignment="Center" Click="EditBtn_Click"></Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Name="TBNumRecords" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"></TextBlock>
            <TextBlock Text="Выводить по:" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"></TextBlock>
            <ComboBox Name="PageSizeComboBox" Height="25" Width="60" FontSize="15" VerticalAlignment="Center" SelectionChanged="PageSizeComboBox_SelectionChanged">
                <TextBlock>10</TextBlock>
                <TextBlock>50</TextBlock>
                <TextBlock>200</TextBlock>
                <TextBlock>Все</TextBlock>
            </ComboBox>
            <Button Name="LeftDirButton" Content="&lt;" Height="25" Width="20" Click="LeftDirButton_Click"></Button>
            <ListBox FontSize="20" Name="PageListBox" SelectionChanged="PageListBox_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Name="RightDirButton" Content="&gt;" Height="25" Width="20" Click="RightDirButton_Click"></Button>
        </StackPanel>
    </Grid>
</Page>
