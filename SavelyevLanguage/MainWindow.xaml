<Window x:Class="SavelyevLanguage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SavelyevLanguage"
        mc:Ignorable="d"
        Title="SavelyevLanguage" Height="450" Width="800" MinHeight="450" MinWidth="800" FontFamily="Comic Sans MS" Icon="/res/school_logo.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#FFE7FABF">
            <Image Source="res/school_logo.png" HorizontalAlignment="Left" ></Image>
            <TextBlock Text="Лангуаге" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock> 
        </Grid>
        <Frame Grid.Row="1" Name="MainFrame" ContentRendered="MainFrame_ContentRendered" NavigationUIVisibility="Hidden"></Frame>
        <Button Content="Назад" HorizontalAlignment="Right" Margin="0,0,10,0" Name="ButtonBack" Click="ButtonBack_Click"></Button>
    </Grid>
</Window>
