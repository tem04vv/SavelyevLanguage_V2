<Page x:Class="SavelyevLanguage.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SavelyevLanguage"
      
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditPage" FontFamily="Comic Sans MS"
      xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Page.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>
    </Page.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="55"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ID:" Grid.Row="0" Grid.Column="0" Name="ID_TextBlock"></TextBlock>
        <TextBox Name="ID_TextBox" Height="20" Width="200" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" IsReadOnly="True"></TextBox>
        
        <TextBlock Text="Фамилия:" Grid.Row="1" Grid.Column="0"></TextBlock>
        <TextBox Name="FirstName_TextBox" Height="20" Width="200" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left"></TextBox>

        <TextBlock Text="Имя:" Grid.Row="2" Grid.Column="0"></TextBlock>
        <TextBox Name="LastName_TextBox" Height="20" Width="200" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left"></TextBox>
        
        <TextBlock Text="Отчество:" Grid.Row="3" Grid.Column="0"></TextBlock>
        <TextBox Name="Patronymic_TextBox" Height="20" Width="200" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left"></TextBox>

        <TextBlock Text="Email:" Grid.Row="4" Grid.Column="0"></TextBlock>
        <TextBox Name="Email_TextBox" Height="20" Width="200" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left"></TextBox>
        
        <TextBlock Text="Телефон:" Grid.Row="5" Grid.Column="0"></TextBlock>
        <TextBox Name="Phone_TextBox" Height="20" Width="200" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Left"></TextBox>

        <TextBlock Text="Дата рождения:" Grid.Row="6" Grid.Column="0"></TextBlock>
        <DatePicker Name="Birthday_DatePicker" Height="40" Width="200" Grid.Row="6" Grid.Column="1" HorizontalAlignment="Left"
                    DisplayDateEnd="{x:Static sys:DateTime.Now}"></DatePicker>

        <TextBlock Text="Пол:" Grid.Row="7" Grid.Column="0"></TextBlock>
        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Vertical">
            <RadioButton Name="FemaleRB" Content ="женский" GroupName="Gender" Margin="0,5,0,0"></RadioButton>
            <RadioButton Name="MaleRB" Content ="мужской" GroupName="Gender" Margin="0,5,0,5"></RadioButton>
        </StackPanel>


        <TextBlock Text="Фото" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center"></TextBlock>
        <Image Name="ClientPhoto" Height="150" Width="150" Grid.Row="1" Grid.Column="2" Grid.RowSpan="5">
            <Image.Source>
                <Binding Path="PhotoPath" TargetNullValue='res/picture.png'></Binding>
            </Image.Source>
        </Image>
        <Button Content="Изменить фото" Name="ChangeBtn" Grid.Row="6" Grid.Column="2" HorizontalAlignment="Center" Click="ChangeBtn_Click"></Button>

        <Button Content="Сохранить" Name="SaveBtn" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Center" Click="SaveBtn_Click"></Button>
    </Grid>
</Page>
